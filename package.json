{
  "name": "deepseek-reasonix",
  "displayName": "pcbtool.net",
  "description": "一键启动 Reasonix 终端，无需手动输入命令。One-click launch Reasonix terminal without typing commands.",
  "version": "0.2.0",
  "publisher": "pcbtool.net",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onView:reasonix.sidebar"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "reasonix",
          "title": "Reasonix",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "reasonix": [
        {
          "type": "webview",
          "id": "reasonix.sidebar",
          "name": "Reasonix"
        }
      ]
    },
    "commands": [
      {
        "command": "reasonix.launch",
        "title": "Reasonix: 启动终端"
      }
    ]
  },
  "scripts": {
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish"
  }
}
